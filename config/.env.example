# ============================================================
# partner-decode-female-agent — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================

# ----------------------------------------------------------
# LLM API Keys
# ----------------------------------------------------------
# Anthropic Claude (primary reasoning engine)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (fallback provider)
OPENAI_API_KEY=your_openai_key_here

# Ollama local server (offline/privacy mode)
OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------------
# Model Selection (override defaults from agent_config.yaml)
# ----------------------------------------------------------
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
OLLAMA_MODEL=llama3

# ----------------------------------------------------------
# Privacy Mode
# Set to "true" to force ALL LLM calls to Ollama only.
# No audio, text, or analysis data will be sent to any cloud API.
# ----------------------------------------------------------
PRIVACY_MODE=false

# ----------------------------------------------------------
# HuggingFace (required for gated models like whisper-large-v3)
# Get your token at: https://huggingface.co/settings/tokens
# ----------------------------------------------------------
HF_TOKEN=your_hf_token_here

# Optional: override which HF models to use
# WAV2VEC2_MODEL=facebook/wav2vec2-base
# EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
# WHISPER_MODEL=openai/whisper-large-v3
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# RERANKER_MODEL=BAAI/bge-reranker-large
# SUMMARIZER_MODEL=facebook/bart-large-cnn

# ----------------------------------------------------------
# Agent Settings
# ----------------------------------------------------------
DATA_DIR=./data
MODELS_DIR=./models
HOST=0.0.0.0
PORT=8011
LOG_LEVEL=INFO

# ----------------------------------------------------------
# Feature Toggles
# ----------------------------------------------------------
USE_WAV2VEC2=true
USE_VISUAL_ANALYSIS=true
USE_WHISPER=true

# ----------------------------------------------------------
# Notes
# ----------------------------------------------------------
# - PRIVACY_MODE=true ensures NO data is sent to Anthropic or OpenAI.
#   All analysis runs locally via Ollama. Accuracy may be lower.
# - HF_TOKEN is required for downloading whisper-large-v3 (gated model).
#   Without it, the agent falls back to whisper-medium.
# - ANTHROPIC_API_KEY is required for the primary empathy report generation.
#   Without it, the agent falls back to OpenAI, then Ollama.
